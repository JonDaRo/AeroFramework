<?xml version='1.0' encoding='utf-8'?>
<xflscript version="1.0">
    <Metadata>
        <Make_project_file>true</Make_project_file>
        <Polar_text_output_format>CSV</Polar_text_output_format>
        <Directories>
            <output_dir></output_dir>
            <plane_definition_xml_dir></plane_definition_xml_dir>
            <plane_analysis_xml_dir></plane_analysis_xml_dir>
            <foil_files_dir></foil_files_dir>
            <foil_polars_dir></foil_polars_dir>
            <xfoil_polars_dir></xfoil_polars_dir>
            <recursive_scan>false</recursive_scan>
        </Directories>
        <MultiThreading>
            <Allow_Multithreading>False</Allow_Multithreading>
            <Thread_Priority>Normal</Thread_Priority>
            <Max_threads>1</Max_threads>
